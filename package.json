  "main": "src/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite --port 3001 --strictPort",
    "dev:electron": "wait-on http://localhost:3001 && electron .",
    "dev:web": "vite --port 3000",
    "dev:bot": "node bot-launcher.js",
    "run:voice-bot": "node voice-bot-only.js",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "electron-builder",
    "build:web": "npm run build:renderer",
    "preview": "vite preview",
    "start": "node CDM.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@discordjs/voice": "^0.19.2",
    "clsx": "^2.1.1",
    "discord.js-selfbot-v13": "^3.7.1",
    "electron-store": "^8.1.0",
    "express": "^4.18.2",
    "ffmpeg-static": "^5.3.0",
    "libsodium-wrappers": "^0.8.4",
    "lucide-react": "^1.14.0",
    "opusscript": "^0.0.8",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.14",
